.confirm-list {
  margin-top: 20rpx;
}

.confirm-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
}

.confirm-item:last-child {
  border-bottom: none;
}

.confirm-item__image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 18rpx;
}

.confirm-item__body {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 8rpx;
}

.confirm-item__name {
  font-size: 28rpx;
  font-weight: 600;
  color: #f5f1e8;
}

.confirm-item__price {
  font-size: 22rpx;
  color: #c9a96b;
}

.remark-box {
  margin-top: 24rpx;
}

.summary-list {
  margin-top: 20rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.submit-error {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(185, 74, 72, 0.12);
  color: #b94a48;
  font-size: 22rpx;
}

.confirm-submit {
  margin-top: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
