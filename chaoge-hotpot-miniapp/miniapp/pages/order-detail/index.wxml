<view class="page-shell order-detail-page">
  <view class="page-header">
    <text class="page-title">订单详情</text>
    <text class="page-subtitle">查看本桌订单明细与状态。</text>
  </view>

  <block wx:if="{{loading}}">
    <empty-state type="loading" />
  </block>

  <block wx:elif="{{errorType}}">
    <empty-state
      type="{{errorType}}"
      title="订单详情加载失败"
      description="请返回订单列表后重试。"
    />
  </block>

  <block wx:elif="{{order}}">
    <view class="card">
      <view class="meta-row">
        <view>
          <text class="detail-no__label">订单号</text>
          <text class="detail-no__value">{{order.orderNo}}</text>
        </view>
        <status-tag status="{{order.status}}" />
      </view>
      <view class="detail-meta">
        <text class="detail-meta__text">下单时间：{{order.createdAtText}}</text>
        <text class="detail-meta__text">就餐人数：{{order.peopleCount}} 位</text>
      </view>
    </view>

    <view class="card section-gap">
      <text class="card-title">菜品明细</text>
      <view class="detail-item-list">
        <view wx:for="{{order.items}}" wx:key="dishId" class="detail-item hairline">
          <image class="detail-item__image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="detail-item__body">
            <text class="detail-item__name">{{item.name}}</text>
            <text class="detail-item__meta">{{item.quantity}} 份 · ¥{{item.price}}/{{item.unit}}</text>
          </view>
          <text class="detail-item__amount">¥{{item.lineAmountText}}</text>
        </view>
      </view>
    </view>

    <view class="card section-gap">
      <text class="card-title">金额与备注</text>
      <view class="summary-row">
        <text class="text-muted">订单金额</text>
        <text class="text-body">¥{{order.totalAmountText}}</text>
      </view>
      <view class="summary-row">
        <text class="text-muted">订单状态</text>
        <text class="text-body">{{order.statusText}}</text>
      </view>
      <view class="detail-remark">
        <text class="text-muted">备注</text>
        <text class="detail-remark__content">{{order.remarkText}}</text>
      </view>
    </view>
  </block>
</view>
