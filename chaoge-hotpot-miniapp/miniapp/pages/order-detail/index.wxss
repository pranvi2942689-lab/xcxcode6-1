.detail-no__label {
  display: block;
  font-size: 22rpx;
  color: #8e857b;
}

.detail-no__value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #f5f1e8;
}

.detail-meta {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-meta__text {
  font-size: 22rpx;
  color: #b8aea3;
}

.detail-item-list {
  margin-top: 20rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-item__image {
  width: 108rpx;
  height: 108rpx;
  border-radius: 16rpx;
}

.detail-item__body {
  flex: 1;
  min-width: 0;
}

.detail-item__name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f5f1e8;
}

.detail-item__meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8e857b;
}

.detail-item__amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #c9a96b;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.detail-remark {
  margin-top: 20rpx;
}

.detail-remark__content {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #f5f1e8;
}
