<view class="page-shell orders-page">
  <view class="page-header">
    <text class="page-title">订单列表</text>
    <text class="page-subtitle">按下单时间倒序展示本机已可见订单。</text>
  </view>

  <block wx:if="{{loading}}">
    <empty-state type="loading" />
  </block>

  <block wx:elif="{{errorType}}">
    <empty-state
      type="{{errorType}}"
      title="订单加载失败"
      description="请稍后重新获取订单列表。"
      buttonText="重新加载"
      bind:action="fetchOrders"
    />
  </block>

  <block wx:elif="{{!orders.length}}">
    <empty-state
      type="empty"
      title="暂无订单"
      description="先去菜单页完成一笔下单。"
      buttonText="去点餐"
      bind:action="goMenu"
    />
  </block>

  <block wx:else>
    <view class="order-list">
      <view wx:for="{{orders}}" wx:key="id" class="order-card card" data-id="{{item.id}}" bindtap="openOrderDetail">
        <view class="meta-row">
          <text class="order-card__no">{{item.orderNo}}</text>
          <status-tag status="{{item.status}}" />
        </view>
        <text class="order-card__summary">{{item.itemSummary}}</text>
        <view class="order-card__footer">
          <view>
            <text class="order-card__time">{{item.createdAtText}}</text>
            <text class="order-card__people">{{item.peopleCount}} 位用餐</text>
          </view>
          <text class="order-card__amount">¥{{item.totalAmountText}}</text>
        </view>
      </view>
    </view>
  </block>
</view>
