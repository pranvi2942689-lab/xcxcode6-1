.hero {
  position: relative;
  overflow: hidden;
  min-height: 420rpx;
  padding: 0;
}

.hero__image {
  width: 100%;
  height: 420rpx;
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(15, 15, 16, 0.2) 0%, rgba(15, 15, 16, 0.86) 100%);
}

.hero__content {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(201, 169, 107, 0.1);
  border: 1rpx solid rgba(201, 169, 107, 0.2);
  color: #c9a96b;
  font-size: 20rpx;
  font-weight: 500;
}

.hero__title {
  display: block;
  margin-top: 20rpx;
  font-size: 44rpx;
  font-weight: 600;
  color: #f5f1e8;
}

.hero__slogan {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #f5f1e8;
}

.hero__meta {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #b8aea3;
  line-height: 1.7;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
}

.hero-actions ui-button {
  flex: 1;
}

.recommend-list,
.signature-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recommend-card {
  display: flex;
  gap: 18rpx;
}

.recommend-card__image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 18rpx;
}

.recommend-card__body {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.recommend-card__title,
.signature-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f5f1e8;
}

.recommend-card__subtitle,
.signature-card__subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #b8aea3;
}

.recommend-card__desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8e857b;
}

.recommend-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 16rpx;
}

.recommend-card__price,
.signature-card__price {
  font-size: 30rpx;
  font-weight: 600;
  color: #c9a96b;
}

.signature-card__image {
  width: 100%;
  height: 220rpx;
  border-radius: 18rpx;
}

.signature-card__bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 16rpx;
}

.signature-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
