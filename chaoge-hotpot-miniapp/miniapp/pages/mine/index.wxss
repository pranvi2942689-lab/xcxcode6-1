.store-card {
  overflow: hidden;
  padding: 0;
}

.store-card__hero {
  width: 100%;
  height: 300rpx;
}

.store-card__body {
  padding: 20rpx;
}

.store-card__name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #f5f1e8;
}

.store-card__slogan {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #c9a96b;
}

.store-card__meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #b8aea3;
}

.mine-actions {
  display: flex;
  gap: 16rpx;
}

.mine-actions ui-button {
  flex: 1;
}

.brand-intro {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.9;
  color: #b8aea3;
}
