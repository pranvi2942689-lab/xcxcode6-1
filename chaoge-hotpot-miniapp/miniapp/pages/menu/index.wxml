<view class="page-shell menu-page">
  <view class="page-header">
    <text class="page-title">今日点餐</text>
    <text class="page-subtitle">先定锅底，再补齐本桌菜品。</text>
  </view>

  <block wx:if="{{loading}}">
    <empty-state type="loading" />
  </block>

  <block wx:elif="{{errorType}}">
    <empty-state
      type="{{errorType}}"
      title="菜单加载失败"
      description="请检查服务连通性后重新获取。"
      buttonText="重新加载"
      bind:action="fetchMenuData"
    />
  </block>

  <block wx:else>
    <view class="menu-layout">
      <view class="category-panel card-secondary">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="{{item.itemClass}}"
          data-id="{{item.id}}"
          bindtap="handleSelectCategory"
        >
          <text class="category-item__name">{{item.name}}</text>
        </view>
      </view>

      <view class="dish-panel">
        <section-title
          title="{{currentCategoryName}}"
          subtitle="点击菜品卡片可查看详情"
        />

        <view class="dish-list section-gap" wx:if="{{visibleDishes.length}}">
          <dish-card
            wx:for="{{visibleDishes}}"
            wx:key="id"
            dish="{{item}}"
            quantity="{{item.cartQuantity}}"
            bind:changequantity="handleDishQuantityChange"
            bind:viewdetail="handleViewDetail"
          />
        </view>

        <empty-state
          wx:else
          type="empty"
          title="当前分类暂无菜品"
          description="请切换其他分类继续点餐。"
        />
      </view>
    </view>

    <view class="safe-bottom-space"></view>
    <cart-bar
      quantity="{{cartSummary.totalQuantity}}"
      amount="{{cartAmountText}}"
      disabled="{{cartDisabled}}"
      buttonText="确认下单"
      bind:submit="goConfirm"
    />
  </block>

  <view wx:if="{{detailVisible}}" class="detail-mask" catchtap="closeDetail">
    <view class="detail-sheet" catchtap="noop">
      <block wx:if="{{detailLoading}}">
        <empty-state type="loading" />
      </block>

      <block wx:elif="{{detailErrorType}}">
        <empty-state
          type="{{detailErrorType}}"
          title="菜品详情加载失败"
          description="请关闭后重试。"
        />
      </block>

      <block wx:elif="{{detailDish}}">
        <image class="detail-sheet__image" src="{{detailDish.image}}" mode="aspectFill"></image>
        <view class="detail-sheet__content">
          <text class="detail-sheet__title">{{detailDish.name}}</text>
          <text class="detail-sheet__subtitle">{{detailDish.subtitle}}</text>
          <view class="detail-sheet__tags">
            <text wx:for="{{detailDish.tags}}" wx:key="*this" class="pill-tag">{{item}}</text>
            <text wx:if="{{detailDish.isSoldOut}}" class="detail-sheet__soldout">暂时售罄</text>
          </view>
          <text class="detail-sheet__description">{{detailDish.description}}</text>
          <view class="detail-sheet__footer">
            <view>
              <text class="detail-sheet__price">¥{{detailDish.price}}</text>
              <text class="detail-sheet__unit">/{{detailDish.unit}}</text>
            </view>
            <qty-stepper
              value="{{detailQuantity}}"
              disabled="{{detailDish.isSoldOut}}"
              bind:change="handleDetailQuantityChange"
            />
          </view>
          <ui-button text="收起详情" type="secondary" block bind:tap="closeDetail" />
        </view>
      </block>
    </view>
  </view>
</view>
