.menu-layout {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.category-panel {
  width: 180rpx;
  padding: 14rpx;
}

.category-item {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 0 16rpx;
  border-radius: 18rpx;
  color: #8e857b;
}

.category-item + .category-item {
  margin-top: 12rpx;
}

.category-item--active {
  background: rgba(201, 169, 107, 0.12);
  color: #f5f1e8;
}

.category-item__name {
  font-size: 24rpx;
  font-weight: 500;
}

.dish-panel {
  flex: 1;
  min-width: 0;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.detail-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 15, 16, 0.7);
}

.detail-sheet {
  width: 100%;
  max-height: 88vh;
  overflow: hidden;
  border-radius: 32rpx 32rpx 0 0;
  background: #17181a;
  border-top: 1rpx solid rgba(201, 169, 107, 0.2);
}

.detail-sheet__image {
  width: 100%;
  height: 360rpx;
}

.detail-sheet__content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx;
}

.detail-sheet__title {
  font-size: 36rpx;
  font-weight: 600;
  color: #f5f1e8;
}

.detail-sheet__subtitle {
  font-size: 24rpx;
  color: #b8aea3;
}

.detail-sheet__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.detail-sheet__soldout {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(185, 74, 72, 0.12);
  color: #b94a48;
  font-size: 20rpx;
}

.detail-sheet__description {
  font-size: 24rpx;
  line-height: 1.8;
  color: #8e857b;
}

.detail-sheet__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-sheet__price {
  font-size: 38rpx;
  font-weight: 600;
  color: #c9a96b;
}

.detail-sheet__unit {
  font-size: 22rpx;
  color: #b8aea3;
}
