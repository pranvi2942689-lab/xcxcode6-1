.qty-stepper {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.qty-stepper__button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: #1e2023;
  border: 1rpx solid rgba(201, 169, 107, 0.18);
  color: #f5f1e8;
  font-size: 28rpx;
  font-weight: 600;
}

.qty-stepper__button--accent {
  background: rgba(201, 169, 107, 0.12);
  color: #c9a96b;
}

.qty-stepper__button--disabled {
  opacity: 0.35;
}

.qty-stepper__value {
  min-width: 34rpx;
  text-align: center;
  font-size: 26rpx;
  color: #f5f1e8;
}
