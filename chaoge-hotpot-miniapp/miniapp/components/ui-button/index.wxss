.ui-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: auto;
  height: 88rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
}

.ui-button--block {
  width: 100%;
}

.ui-button--default {
  height: 88rpx;
}

.ui-button--small {
  height: 52rpx;
  padding: 0 20rpx;
}

.ui-button--primary {
  background: linear-gradient(135deg, #c9a96b 0%, #b58e4d 100%);
  color: #0f0f10;
}

.ui-button--secondary {
  background: #1e2023;
  border: 1rpx solid rgba(201, 169, 107, 0.24);
  color: #f5f1e8;
}

.ui-button--ghost {
  background: rgba(201, 169, 107, 0.08);
  border: 1rpx solid rgba(201, 169, 107, 0.18);
  color: #c9a96b;
}

.ui-button--disabled {
  opacity: 0.45;
}

.ui-button__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.ui-button__text {
  font-size: 28rpx;
  font-weight: 600;
}

.ui-button__spinner {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(15, 15, 16, 0.22);
  border-top-color: rgba(15, 15, 16, 0.9);
  animation: ui-button-spin 0.8s linear infinite;
}

@keyframes ui-button-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
