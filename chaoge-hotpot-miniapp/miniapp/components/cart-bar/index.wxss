.cart-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 20;
  padding-bottom: env(safe-area-inset-bottom);
}

.cart-bar__panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 120rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: rgba(23, 24, 26, 0.96);
  border: 1rpx solid rgba(201, 169, 107, 0.18);
}

.cart-bar__summary {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cart-bar__label {
  font-size: 24rpx;
  color: #b8aea3;
}

.cart-bar__amount {
  font-size: 36rpx;
  font-weight: 600;
  color: #c9a96b;
}
