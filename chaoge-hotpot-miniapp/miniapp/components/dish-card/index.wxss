.dish-card {
  display: flex;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #17181a;
  border: 1rpx solid rgba(201, 169, 107, 0.18);
}

.dish-card--soldout {
  opacity: 0.78;
}

.dish-card__image {
  flex-shrink: 0;
  width: 176rpx;
  height: 176rpx;
  border-radius: 18rpx;
  background: #1e2023;
}

.dish-card__body {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  justify-content: space-between;
}

.dish-card__head {
  min-height: 74rpx;
}

.dish-card__name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #f5f1e8;
}

.dish-card__subtitle {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #b8aea3;
}

.dish-card__description {
  min-height: 72rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8e857b;
}

.dish-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
  min-height: 36rpx;
}

.dish-card__tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(201, 169, 107, 0.08);
  border: 1rpx solid rgba(201, 169, 107, 0.18);
  font-size: 20rpx;
  color: #c9a96b;
}

.dish-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
}

.dish-card__price-box {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  min-width: 0;
}

.dish-card__currency,
.dish-card__unit {
  font-size: 22rpx;
  color: #b8aea3;
}

.dish-card__price {
  font-size: 36rpx;
  font-weight: 600;
  color: #c9a96b;
}

.dish-card__action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 168rpx;
}

.dish-card__soldout {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(185, 74, 72, 0.12);
  border: 1rpx solid rgba(185, 74, 72, 0.2);
  font-size: 22rpx;
  color: #b94a48;
}
