.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 80rpx 24rpx;
  text-align: center;
}

.empty-state__badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(201, 169, 107, 0.08);
  border: 1rpx solid rgba(201, 169, 107, 0.18);
}

.empty-state__badge-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #c9a96b;
}

.empty-state__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f5f1e8;
}

.empty-state__description {
  max-width: 540rpx;
  font-size: 24rpx;
  color: #8e857b;
}

.empty-state__button {
  min-width: 200rpx;
  height: 52rpx;
  margin-top: 8rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #1e2023;
  border: 1rpx solid rgba(201, 169, 107, 0.18);
  color: #c9a96b;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-state__spinner {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(201, 169, 107, 0.18);
  border-top-color: #c9a96b;
  animation: empty-spin 0.8s linear infinite;
}

@keyframes empty-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
