.success-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 80rpx 40rpx;
  margin-top: 120rpx;
}

.success-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 52rpx;
  background: #22b45a;
}

.success-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 84rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #22b45a, #18964a);
}

.success-btn--ghost {
  color: #4b5563;
  background: #ffffff;
  border: 2rpx solid #d5d9e0;
}
