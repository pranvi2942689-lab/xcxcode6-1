<view class="page page--safe">
  <filter-tabs tabs="{{tabs}}" value="{{currentStatus}}" bind:change="changeTab" />

  <block wx:if="{{!hasLogin}}">
    <empty-state title="登录后查看订单" desc="可跟踪状态、查看配送与售后" actionText="去登录" bind:action="goLogin" />
  </block>

  <block wx:elif="{{!orders.length}}">
    <empty-state title="暂无订单" desc="下单后可在这里查看配送状态" />
  </block>

  <block wx:else>
    <order-card wx:for="{{orders}}" wx:key="id" order="{{item}}" bind:tap="openDetail" bind:action="handleAction" />
  </block>
</view>
