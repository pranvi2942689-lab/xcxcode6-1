<view wx:if="{{order}}" class="page page--safe">
  <view class="card card-pad">
    <view class="row-between">
      <view class="text-title">订单状态</view>
      <status-tag status="{{order.status}}" />
    </view>
    <view class="text-muted section-gap">{{order.deliverySlot}}</view>
  </view>

  <view class="card card-pad section-gap">
    <view class="text-title">收货地址</view>
    <view class="detail-text">{{order.addressSnapshot.name}} {{order.addressSnapshot.phone}}</view>
    <view class="detail-text">{{order.addressSnapshot.communityName}} {{order.addressSnapshot.detail}} {{order.addressSnapshot.houseNumber}}</view>
  </view>

  <view class="card card-pad section-gap">
    <view class="text-title">商品明细</view>
    <view wx:for="{{order.items}}" wx:key="goodsId" class="detail-item">
      <text>{{item.name}}</text>
      <text class="text-muted">x{{item.quantity}} · ¥{{item.subtotal}}</text>
    </view>
  </view>

  <view class="card card-pad section-gap">
    <view class="detail-item"><text>商品金额</text><text>¥{{order.goodsAmount}}</text></view>
    <view class="detail-item"><text>优惠金额</text><text>-¥{{order.discountAmount}}</text></view>
    <view class="detail-item"><text>配送费</text><text>¥{{order.deliveryFee}}</text></view>
    <view class="detail-item"><text>订单编号</text><text>{{order.orderNo}}</text></view>
    <view class="detail-item"><text>下单时间</text><text>{{order.createdAt}}</text></view>
  </view>

  <bottom-action-bar wx:if="{{primaryVisible}}" leftText="实付 ¥{{order.payableAmount}}" leftSubText="{{order.orderNo}}" buttonText="{{primaryText}}" bind:submit="handlePrimary" />
  <view wx:if="{{serviceVisible}}" class="service-link fixed-safe-bottom" bindtap="goService">申请售后 / 查看售后</view>
</view>
