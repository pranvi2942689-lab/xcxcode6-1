.detail-text,
.detail-item {
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 36rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.service-link {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  color: #22b45a;
  background: #ffffff;
  border: 2rpx solid #22b45a;
}
