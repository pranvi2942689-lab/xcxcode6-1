.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  font-size: 24rpx;
  border-bottom: 2rpx solid #eef1f4;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item__value {
  max-width: 380rpx;
  color: #8a94a6;
  text-align: right;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #f04438, #e34d3e);
}
