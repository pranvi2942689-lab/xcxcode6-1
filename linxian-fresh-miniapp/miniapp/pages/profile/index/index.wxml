<view class="page page--safe">
  <view class="profile-hero card">
    <image wx:if="{{avatarUrl}}" class="profile-hero__avatar" src="{{avatarUrl}}" mode="aspectFill" />
    <view wx:else class="profile-hero__avatar profile-hero__avatar--placeholder">邻鲜</view>
    <view class="profile-hero__body">
      <view class="profile-hero__name">{{hasLogin ? userProfile.nickname : '立即登录'}}</view>
      <view class="profile-hero__desc">{{hasLogin ? '优鲜会员 · 社区家庭用户' : '登录后同步购物车、订单与卡券'}}</view>
    </view>
    <view wx:if="{{!hasLogin}}" class="profile-hero__action" bindtap="goLogin">去登录</view>
  </view>

  <view class="card profile-orders section-gap">
    <view class="text-title">我的订单</view>
    <view class="profile-orders__grid">
      <view class="profile-orders__item" data-status="pending_payment" bindtap="goOrders">待支付</view>
      <view class="profile-orders__item" data-status="pending_delivery" bindtap="goOrders">待配送</view>
      <view class="profile-orders__item" data-status="delivering" bindtap="goOrders">配送中</view>
      <view class="profile-orders__item" data-status="completed" bindtap="goOrders">已完成</view>
    </view>
  </view>

  <view class="card profile-assets section-gap">
    <view class="profile-assets__head">
      <view class="text-title">我的资产</view>
      <view class="profile-assets__link" bindtap="goCouponCenter">领券中心</view>
    </view>
    <view class="profile-assets__grid">
      <view class="profile-assets__item">
        <view class="profile-assets__num">{{stats.couponCount}}</view>
        <view class="text-muted">优惠券</view>
      </view>
      <view class="profile-assets__item">
        <view class="profile-assets__num">{{stats.favoriteCount}}</view>
        <view class="text-muted">收藏</view>
      </view>
      <view class="profile-assets__item">
        <view class="profile-assets__num">{{stats.orderCount}}</view>
        <view class="text-muted">订单</view>
      </view>
    </view>
  </view>

  <view class="profile-banner card section-gap" bindtap="goNewcomer">
    <view class="profile-banner__title">新人专享礼包</view>
    <view class="profile-banner__desc">10 元 / 20 元 / 50 元组合券包限时领取</view>
  </view>

  <view class="card section-gap">
    <view wx:for="{{menus}}" wx:key="title" class="profile-menu" data-url="{{item.url}}" bindtap="goMenu">
      <view>{{item.title}}</view>
      <view class="text-muted">›</view>
    </view>
  </view>
</view>
