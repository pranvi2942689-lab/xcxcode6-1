.profile-hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  background: linear-gradient(135deg, #22b45a, #4fc978);
}

.profile-hero__avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
}

.profile-hero__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #22b45a;
  font-size: 26rpx;
  font-weight: 700;
  background: #ffffff;
}

.profile-hero__body {
  flex: 1;
  color: #ffffff;
}

.profile-hero__name {
  font-size: 34rpx;
  font-weight: 700;
}

.profile-hero__desc {
  margin-top: 10rpx;
  font-size: 22rpx;
}

.profile-hero__action {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #22b45a;
  font-size: 24rpx;
  font-weight: 700;
}

.profile-orders,
.profile-assets,
.profile-banner {
  padding: 20rpx;
}

.profile-orders__grid,
.profile-assets__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 18rpx;
}

.profile-orders__item,
.profile-assets__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 0;
  border-radius: 20rpx;
  background: #f8faf9;
}

.profile-assets__head,
.profile-menu {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.profile-assets__link {
  color: #22b45a;
  font-size: 24rpx;
}

.profile-assets__num {
  color: #1f2a37;
  font-size: 32rpx;
  font-weight: 700;
}

.profile-banner {
  background: linear-gradient(135deg, #ffffff, #f7fbe8);
}

.profile-banner__title {
  color: #1f2a37;
  font-size: 30rpx;
  font-weight: 700;
}

.profile-banner__desc {
  margin-top: 10rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.profile-menu {
  min-height: 88rpx;
  border-bottom: 2rpx solid #eef1f4;
  font-size: 26rpx;
}

.profile-menu:last-child {
  border-bottom: none;
}
