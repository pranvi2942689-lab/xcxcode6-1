<view class="page page--safe">
  <search-bar value="{{keyword}}" placeholder="搜索蔬菜水果、肉禽蛋奶" bind:change="onKeywordChange" bind:search="onSearch" />

  <view class="search-block card section-gap">
    <view class="text-title">搜索历史</view>
    <view class="tag-group">
      <view wx:for="{{history}}" wx:key="*this" class="tag" data-keyword="{{item}}" bindtap="tapHistory">{{item}}</view>
    </view>
  </view>

  <view class="search-block card section-gap">
    <view class="text-title">热门搜索</view>
    <view class="tag-group">
      <view wx:for="{{hotKeywords}}" wx:key="*this" class="tag tag--active" data-keyword="{{item}}" bindtap="tapHistory">{{item}}</view>
    </view>
  </view>

  <view class="section-gap">
    <goods-card-list wx:for="{{result}}" wx:key="id" goods="{{item}}" bind:tap="goDetail" bind:add="addCart" />
    <empty-state wx:if="{{keyword && !result.length}}" title="暂无搜索结果" desc="换个关键词再试试" />
  </view>
</view>
