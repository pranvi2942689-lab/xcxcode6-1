<view class="page page--safe">
  <address-card wx:if="{{address}}" address="{{address}}" bind:tap="chooseAddress" />
  <empty-state wx:else title="暂无收货地址" desc="请先新增地址" actionText="去添加" bind:action="chooseAddress" />

  <view wx:if="{{preview}}" class="card card-pad section-gap">
    <view class="row-between">
      <view class="text-title">配送时间</view>
      <view class="text-muted">{{deliverySlot}}</view>
    </view>
    <view class="slot-group">
      <view wx:for="{{preview.deliverySlots}}" wx:key="id" class="slot-item {{deliverySlot === item.label ? 'is-active' : ''}}" data-value="{{item.label}}" bindtap="chooseSlot">{{item.label}}</view>
    </view>
  </view>

  <view wx:if="{{preview}}" class="card card-pad section-gap">
    <view class="text-title">商品清单</view>
    <view wx:for="{{preview.items}}" wx:key="goodsId" class="checkout-item">
      <view>{{item.name}}</view>
      <view class="text-muted">x{{item.quantity}} · ¥{{item.subtotal}}</view>
    </view>
  </view>

  <view wx:if="{{preview}}" class="card card-pad section-gap" bindtap="chooseCoupon">
    <view class="row-between">
      <view class="text-title">优惠券</view>
      <view class="text-muted">{{selectedCoupon ? '已选优惠券' : '选择优惠券'}} ›</view>
    </view>
  </view>

  <view class="card card-pad section-gap">
    <view class="text-title">订单备注</view>
    <textarea class="remark-box" placeholder="如有配送要求可备注给骑手" bindinput="updateRemark" />
  </view>

  <view wx:if="{{preview}}" class="card card-pad section-gap">
    <view class="amount-row"><text>商品金额</text><text>¥{{preview.goodsAmount}}</text></view>
    <view class="amount-row"><text>优惠金额</text><text>-¥{{preview.discountAmount}}</text></view>
    <view class="amount-row"><text>配送费</text><text>¥{{preview.deliveryFee}}</text></view>
    <view class="amount-row amount-row--total"><text>实付金额</text><text>¥{{preview.payableAmount}}</text></view>
  </view>

  <bottom-action-bar wx:if="{{preview}}" leftText="实付 ¥{{preview.payableAmount}}" leftSubText="{{deliverySlot}}" buttonText="提交订单并模拟支付" bind:submit="submitOrder" />
</view>
