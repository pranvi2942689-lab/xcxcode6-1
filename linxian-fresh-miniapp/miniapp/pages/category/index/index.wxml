<view class="page page--safe category-page">
  <view class="category-side card">
    <view wx:for="{{categories}}" wx:key="id" class="category-side__item {{currentCategoryId === item.id ? 'is-active' : ''}}" data-id="{{item.id}}" bindtap="switchCategory">
      {{item.name}}
    </view>
  </view>
  <view class="category-main">
    <view class="category-banner card">
      <view class="category-banner__title">{{currentCategory.name}}</view>
      <view class="category-banner__desc">{{currentCategory.desc}}</view>
    </view>
    <view wx:if="{{goodsList.length}}" class="category-grid">
      <goods-card-grid wx:for="{{goodsList}}" wx:key="id" goods="{{item}}" bind:tap="goDetail" bind:add="addCart" />
    </view>
    <empty-state wx:else title="当前分类暂无商品" desc="稍后再来看看" />
  </view>
</view>
