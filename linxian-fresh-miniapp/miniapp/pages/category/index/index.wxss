.category-page {
  display: flex;
  gap: 16rpx;
}

.category-side {
  width: 180rpx;
  padding: 12rpx;
}

.category-side__item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  border-radius: 18rpx;
  color: #4b5563;
  font-size: 24rpx;
}

.category-side__item.is-active {
  background: #eaf8ef;
  color: #22b45a;
  font-weight: 700;
}

.category-main {
  flex: 1;
}

.category-banner {
  padding: 20rpx;
}

.category-banner__title {
  color: #1f2a37;
  font-size: 30rpx;
  font-weight: 700;
}

.category-banner__desc {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}
