.detail-image {
  width: 100%;
  height: 620rpx;
}

.detail-base {
  padding: 24rpx;
}

.detail-title {
  color: #1f2a37;
  font-size: 34rpx;
  font-weight: 700;
}

.detail-sub,
.detail-sold,
.detail-text {
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 36rpx;
}

.detail-price-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.detail-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.detail-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eaf8ef;
  color: #22b45a;
  font-size: 20rpx;
}

.detail-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
}

.detail-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #d5d9e0;
  color: #4b5563;
}

.detail-action--primary {
  color: #ffffff;
  background: linear-gradient(135deg, #22b45a, #18964a);
  border: none;
}

.popup-body {
  display: flex;
  gap: 16rpx;
}

.popup-body__image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
}

.popup-body__name {
  color: #1f2a37;
  font-size: 28rpx;
  font-weight: 700;
}

.popup-qty {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
}
