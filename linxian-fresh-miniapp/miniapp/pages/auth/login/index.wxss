.login-box {
  padding: 60rpx 32rpx;
  margin-top: 160rpx;
}

.login-title {
  color: #1f2a37;
  font-size: 40rpx;
  font-weight: 700;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin-top: 40rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #22b45a, #18964a);
}
