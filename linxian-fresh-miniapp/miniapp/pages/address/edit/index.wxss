.input-title {
  margin: 16rpx 0 10rpx;
  color: #4b5563;
  font-size: 24rpx;
}

.default-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  color: #4b5563;
  font-size: 24rpx;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #22b45a, #18964a);
}
