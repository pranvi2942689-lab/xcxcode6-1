.home-hero {
  padding: 24rpx;
  margin-top: 24rpx;
}

.home-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.home-location {
  color: #1f2a37;
  font-size: 34rpx;
  font-weight: 700;
}

.home-location-sub {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.banner-swiper {
  width: 100%;
  height: 260rpx;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  padding: 22rpx 12rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #eaf8ef, #ffffff);
  font-size: 38rpx;
}

.entry-text {
  color: #4b5563;
  font-size: 22rpx;
}

.newcomer {
  padding: 20rpx;
  background: linear-gradient(135deg, #ffffff, #f4fbf6);
}

.newcomer__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.newcomer__link {
  color: #22b45a;
  font-size: 24rpx;
  font-weight: 600;
}

.newcomer__cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 18rpx;
}

.newcomer__item {
  padding: 18rpx;
  border-radius: 20rpx;
  background: #22b45a;
  color: #ffffff;
}

.newcomer__amount {
  font-size: 28rpx;
  font-weight: 700;
}

.newcomer__desc {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
