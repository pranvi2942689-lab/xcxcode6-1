.filter-tabs {
  display: flex;
  padding: 10rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 42, 55, 0.06);
}

.filter-tabs__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  border-radius: 18rpx;
  color: #4b5563;
  font-size: 24rpx;
}

.filter-tabs__item.is-active {
  background: #eaf8ef;
  color: #22b45a;
  font-weight: 700;
}
