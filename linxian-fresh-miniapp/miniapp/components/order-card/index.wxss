.order-card {
  padding: 20rpx;
}

.order-card__head,
.order-card__foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-card__no,
.order-card__time,
.order-card__count {
  color: #8a94a6;
  font-size: 22rpx;
}

.order-card__goods {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
}

.order-card__thumb {
  width: 124rpx;
  height: 124rpx;
  border-radius: 18rpx;
  background: #f3f5f7;
}

.order-card__meta {
  flex: 1;
}

.order-card__name {
  color: #1f2a37;
  font-size: 28rpx;
  font-weight: 600;
}

.order-card__amount {
  color: #1f2a37;
  font-size: 28rpx;
  font-weight: 700;
}

.order-card__actions {
  display: flex;
  gap: 12rpx;
}

.order-card__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d5d9e0;
  color: #4b5563;
  font-size: 24rpx;
}

.order-card__btn--ghost {
  border-color: #22b45a;
  color: #22b45a;
}
