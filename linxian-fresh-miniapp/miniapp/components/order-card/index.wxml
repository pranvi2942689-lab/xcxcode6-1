<view class="order-card card" bindtap="tapCard">
  <view class="order-card__head">
    <view class="order-card__no">订单号 {{order.orderNo}}</view>
    <status-tag status="{{order.status}}" />
  </view>
  <view class="order-card__goods">
    <image class="order-card__thumb" src="{{order.items[0].cover}}" mode="aspectFill" />
    <view class="order-card__meta">
      <view class="order-card__name">{{order.items[0].name}}</view>
      <view class="order-card__count">共 {{order.items.length}} 件商品</view>
      <view class="order-card__time">{{order.createdAt}}</view>
    </view>
  </view>
  <view class="order-card__foot">
    <view class="order-card__amount">实付 ¥{{order.payableAmount}}</view>
    <view class="order-card__actions">
      <view wx:if="{{canPay}}" class="order-card__btn order-card__btn--ghost" data-action="pay" catchtap="tapAction">去支付</view>
      <view wx:if="{{canCancel}}" class="order-card__btn" data-action="cancel" catchtap="tapAction">取消订单</view>
      <view wx:if="{{canConfirm}}" class="order-card__btn order-card__btn--ghost" data-action="confirm" catchtap="tapAction">确认收货</view>
      <view wx:if="{{canService}}" class="order-card__btn order-card__btn--ghost" data-action="service" catchtap="tapAction">申请售后</view>
    </view>
  </view>
</view>
