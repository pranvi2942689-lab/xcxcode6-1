.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-bar__inner {
  flex: 1;
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 42, 55, 0.06);
}

.search-bar__icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-bar__input {
  flex: 1;
  font-size: 26rpx;
}

.search-bar__placeholder {
  color: #b8bec9;
}

.search-bar__action {
  color: #22b45a;
  font-size: 26rpx;
  font-weight: 600;
}
