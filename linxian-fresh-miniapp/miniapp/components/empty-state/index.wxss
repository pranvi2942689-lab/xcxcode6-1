.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 40rpx;
}

.empty-state__icon {
  font-size: 88rpx;
}

.empty-state__title {
  color: #1f2a37;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-state__desc {
  color: #8a94a6;
  font-size: 24rpx;
}
