.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-header__title {
  color: #1f2a37;
  font-size: 30rpx;
  font-weight: 700;
}

.section-header__subtitle {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.section-header__action {
  color: #22b45a;
  font-size: 24rpx;
  font-weight: 600;
}
