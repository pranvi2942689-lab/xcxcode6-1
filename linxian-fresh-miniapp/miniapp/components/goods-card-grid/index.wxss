.goods-grid {
  overflow: hidden;
}

.goods-grid__image {
  width: 100%;
  height: 280rpx;
  background: #f3f5f7;
}

.goods-grid__body {
  padding: 18rpx;
}

.goods-grid__name {
  min-height: 76rpx;
  color: #1f2a37;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.goods-grid__spec,
.goods-grid__origin {
  color: #8a94a6;
  font-size: 22rpx;
}

.goods-grid__tags {
  display: flex;
  gap: 8rpx;
  margin-top: 10rpx;
  min-height: 36rpx;
}

.goods-grid__tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #eaf8ef;
  color: #22b45a;
  font-size: 20rpx;
}

.goods-grid__footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 14rpx;
}

.goods-grid__price {
  color: #e34d3e;
  font-size: 30rpx;
  font-weight: 700;
}

.goods-grid__action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 34rpx;
  background: linear-gradient(135deg, #22b45a, #18964a);
  box-shadow: 0 10rpx 18rpx rgba(34, 180, 90, 0.26);
}
