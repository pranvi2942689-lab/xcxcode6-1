.stepper {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #f3f5f7;
}

.stepper__btn,
.stepper__value {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.stepper__btn {
  background: #ffffff;
  color: #4b5563;
  font-size: 28rpx;
}

.stepper__btn--plus {
  background: #22b45a;
  color: #ffffff;
}

.stepper__value {
  width: 56rpx;
  color: #1f2a37;
  font-size: 24rpx;
  font-weight: 600;
}
