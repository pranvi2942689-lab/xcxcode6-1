.coupon {
  display: flex;
  overflow: hidden;
  min-height: 176rpx;
}

.coupon__left {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #22b45a, #4fc978);
  color: #ffffff;
}

.coupon__amount {
  font-size: 42rpx;
  font-weight: 700;
}

.coupon__threshold {
  font-size: 22rpx;
}

.coupon__body {
  flex: 1;
  padding: 22rpx 20rpx;
}

.coupon__title {
  color: #1f2a37;
  font-size: 28rpx;
  font-weight: 700;
}

.coupon__desc,
.coupon__status {
  margin-top: 10rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.coupon--disabled {
  opacity: 0.6;
}
