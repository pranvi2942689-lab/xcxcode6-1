<view class="coupon card {{coupon.status !== 'active' && coupon.status !== 'available' ? 'coupon--disabled' : ''}}" bindtap="handleTap">
  <view class="coupon__left">
    <view class="coupon__amount">¥{{amountText}}</view>
    <view class="coupon__threshold">满 {{thresholdText}} 可用</view>
  </view>
  <view class="coupon__body">
    <view class="coupon__title">{{titleText}}</view>
    <view class="coupon__desc">{{descText}}</view>
    <view class="coupon__status">{{statusText}}</view>
  </view>
</view>
