.goods-list {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
}

.goods-list__image {
  width: 188rpx;
  height: 188rpx;
  border-radius: 20rpx;
  background: #f3f5f7;
}

.goods-list__body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.goods-list__name {
  color: #1f2a37;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.goods-list__subtitle,
.goods-list__spec,
.goods-list__sold {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.goods-list__bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: auto;
}

.goods-list__price {
  color: #e34d3e;
  font-size: 30rpx;
  font-weight: 700;
}

.goods-list__add {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 56rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  background: linear-gradient(135deg, #22b45a, #18964a);
}
