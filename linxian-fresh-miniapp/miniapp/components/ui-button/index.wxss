.ui-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.ui-button--block {
  width: 100%;
}

.ui-button--primary {
  color: #ffffff;
  background: linear-gradient(135deg, #22b45a, #18964a);
  box-shadow: 0 10rpx 24rpx rgba(34, 180, 90, 0.24);
}

.ui-button--secondary {
  color: #4b5563;
  background: #ffffff;
  border: 2rpx solid #d5d9e0;
}

.ui-button--ghost {
  color: #22b45a;
  background: #eaf8ef;
}

.ui-button--sm {
  height: 56rpx;
}

.ui-button--md {
  height: 76rpx;
}

.ui-button--lg {
  height: 88rpx;
}

.is-disabled {
  color: #8a94a6;
  background: #d5d9e0;
  border-color: #d5d9e0;
  box-shadow: none;
}
