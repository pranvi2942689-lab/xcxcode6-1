.popup {
  position: fixed;
  inset: 0;
  z-index: 99;
}

.popup__mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.36);
}

.popup__panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-shadow: 0 12rpx 40rpx rgba(31, 42, 55, 0.12);
}

.popup__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.popup__title {
  color: #1f2a37;
  font-size: 30rpx;
  font-weight: 700;
}

.popup__close {
  color: #8a94a6;
  font-size: 38rpx;
}

.popup__content {
  max-height: 700rpx;
  margin: 20rpx 0 24rpx;
}
